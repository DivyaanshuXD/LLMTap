{
  "name": "@llmtap/shared",
  "version": "0.1.5",
  "description": "Shared types, constants, and utilities for LLMTap",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "prepack": "node ../../scripts/verify-publish-manifests.mjs .",
    "build": "tsup",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
